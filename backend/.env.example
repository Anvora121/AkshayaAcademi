# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.

# MongoDB Atlas connection string
# Get this from: Atlas Dashboard → Your Cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/akshaya?retryWrites=true&w=majority&appName=<AppName>

# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_A_STRONG_64_CHAR_SECRET

# Server port
PORT=5000

# Frontend URL (used for CORS — no trailing slash)
# Local dev:      http://localhost:5173
# Production:     https://your-frontend-domain.com
FRONTEND_URL=http://localhost:5173

# Comma-separated admin email addresses
ADMIN_EMAILS=admin@example.com
