# ─────────────────────────────────────────────────
# Akshaya Akademics — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.
# ─────────────────────────────────────────────────

# ── MongoDB Atlas ─────────────────────────────────
# Get from: Atlas Dashboard → Your Cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/akshaya?retryWrites=true&w=majority&appName=<AppName>

# ── JWT ───────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_A_STRONG_64_CHAR_SECRET

# ── Server ────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS ─────────────────────────────────────────
# Frontend URL (no trailing slash)
# Local dev:   http://localhost:5173
# Production:  https://akshayaakademics.com
FRONTEND_URL=http://localhost:5173

# ── Admin Seed (used by: npm run create-admin) ────
# Override these when running the seed script, or edit
# the defaults inside backend/src/scripts/createAdmin.ts
ADMIN_EMAIL=admin@akshayaakademics.com
ADMIN_PASSWORD=Admin@2024!
ADMIN_NAME=Akshaya Admin

# ── EmailJS (for password-reset OTP emails) ───────
# Get from: https://www.emailjs.com → Account → API Keys
EMAILJS_SERVICE_ID=your_service_id
EMAILJS_TEMPLATE_ID_OTP=your_otp_template_id
EMAILJS_PUBLIC_KEY=your_public_key
EMAILJS_PRIVATE_KEY=your_private_key
